// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum ProjectRole {
  OWNER
  MEMBER
}

enum AccessType {
  FULL    // Full access — can do everything an owner can except delete project
  EDITOR  // Can create/edit/move tasks and sections they have access to
  VIEWER  // Read-only
}

enum NotificationType {
  COMMENT_ADDED
  TASK_ASSIGNED
  TASK_UNASSIGNED
  TASK_STATUS_CHANGED
  MENTION
}

enum ActivityAction {
  TASK_CREATED
  TASK_UPDATED
  TASK_STATUS_CHANGED
  TASK_MOVED_SECTION
  TASK_ARCHIVED
  TASK_UNARCHIVED
  TASK_DELETED
  COMMENT_ADDED
  COMMENT_DELETED
  SUBTASK_ADDED
  SUBTASK_COMPLETED
  SUBTASK_UNCOMPLETED
  SUBTASK_DELETED
  ASSIGNEE_ADDED
  ASSIGNEE_REMOVED
  TAG_ADDED
  TAG_REMOVED
  ATTACHMENT_UPLOADED
  ATTACHMENT_DELETED
}

// ─── Models ──────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  avatar    String?
  googleId  String   @unique
  createdAt DateTime @default(now())

  ownedProjects    Project[]        @relation("ProjectOwner")
  memberships      ProjectMember[]
  sectionAccess    SectionMember[]
  taskAssignments  TaskAssignee[]
  comments         Comment[]
  notifications    Notification[]   @relation("UserNotifications")
  activities       ActivityLog[]    @relation("UserActivities")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  slug        String   @unique
  createdAt   DateTime @default(now())

  ownerId String
  owner   User   @relation("ProjectOwner", fields: [ownerId], references: [id])

  members   ProjectMember[]
  sections  Section[]
  tags      Tag[]
  templates TaskTemplate[]
}

model ProjectMember {
  id         String      @id @default(cuid())
  role       ProjectRole @default(MEMBER)
  accessType AccessType  @default(FULL)
  joinedAt   DateTime    @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Section {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#6366f1")
  position    Int      @default(0)
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks     Task[]
  templates TaskTemplate[]
  members   SectionMember[]
}

model SectionMember {
  id         String     @id @default(cuid())
  accessType AccessType @default(VIEWER)
  joinedAt   DateTime   @default(now())

  sectionId String
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sectionId, userId])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  status      TaskStatus @default(TODO)
  archived    Boolean    @default(false)
  position    Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  sectionId String
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  comments    Comment[]
  tags        TaskTag[]
  assignees   TaskAssignee[]
  attachments TaskAttachment[]
  subtasks    Subtask[]
  activities  ActivityLog[]     @relation("TaskActivities")
}

model Subtask {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model TaskAttachment {
  id           String   @id @default(cuid())
  filename     String   // original filename shown to users
  storageKey   String   // provider-specific key (local path or blob name)
  mimeType     String
  size         Int      // bytes
  createdAt    DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model TaskAssignee {
  accessType AccessType @default(VIEWER)

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  taskId String
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorId String
  author   User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Tag {
  id    String @id @default(cuid())
  name  String
  color String @default("#6366f1")

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks TaskTag[]

  @@unique([projectId, name])
}

model TaskTag {
  taskId String
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  tagId String
  tag   Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

model TaskTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  fields      Json     @default("[]")
  createdAt   DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  sectionId String?
  section   Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
}

model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  // Recipient
  userId String
  user   User @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  // Context stored at creation time (denormalized so it survives deletions)
  actorName   String
  taskId      String?
  taskTitle   String?
  projectId   String?
  projectName String?
  meta        Json?    // e.g. { newStatus: "DONE" } for status changes
}

model ActivityLog {
  id          String         @id @default(cuid())
  action      ActivityAction
  createdAt   DateTime       @default(now())

  taskId      String
  taskTitle   String
  projectId   String
  sectionId   String?
  sectionName String?
  actorId     String
  actorName   String
  details     Json?

  task  Task @relation("TaskActivities", fields: [taskId], references: [id], onDelete: Cascade)
  actor User @relation("UserActivities", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([projectId])
}
